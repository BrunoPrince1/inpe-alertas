#Prometheus configurando alertas

groups:
  - name: app-alerts
    rules:
      - alert: HighErrorRate
        expr: rate(http_requests_total{status="500"}[5m]) > 5
        for: 1m
        labels:
          severity: critical
        annotations:
          summary: "Alta taxa de erros 500"
          description: "Mais de 5 erros 500 por minuto."
